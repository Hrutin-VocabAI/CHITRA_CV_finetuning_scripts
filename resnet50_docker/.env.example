# ==========================================================
# 🛑 ENVIRONMENT SECRETS AND CONFIGURATION
# Copy this file to `.env` and adjust the paths/values!
# DO NOT COMMIT `.env` to Version Control!
# ==========================================================

# ----------------------------------------------------------
# 📁 1. DATA PATHS (Crucial: How Docker sees your Local Files)
# ----------------------------------------------------------
# Replace this with the ABSOLUTE path to your dataset on your host machine.
# This folder MUST contain the `train`, `val`, and `test` subdirectories.
# Example: /media/vocab/DATA5/SURIYA/CHITRA/DATA/d2d_dataset
HOST_SPLITS_DIR=/path/to/your/splits_dataset

# ----------------------------------------------------------
# 🧠 2. HYPERPARAMETERS
# ----------------------------------------------------------
# The filename you want the model saved as.
# It will be saved into your local: ./output_models/
MODEL_FILENAME=resnet50_d2d_best.keras

# Random Seed for reproducibility
SEED=42

# Image Size (default for ResNet50 is 224)
IMG_SIZE=224

# Batch Size
BATCH_SIZE=32

# Number of epochs for training just the new dense head (Base Model Frozen)
EPOCHS_HEAD=5

# Number of epochs for fine-tuning the whole model
EPOCHS_FT=10

# Learning Rate for the Head training phase
LR_HEAD=0.001

# Learning Rate for the Fine-Tuning phase
LR_FT=0.0001

# How many layers from the end of ResNet50 to unfreeze during fine-tuning phase
UNFREEZE_LAYERS=30
