# ==========================================================
# 🛑 ENVIRONMENT SECRETS AND CONFIGURATION
# Copy this file to `.env` and adjust the paths/values!
# DO NOT COMMIT `.env` to Version Control!
# ==========================================================

# ----------------------------------------------------------
# 📁 1. DATA PATHS (Crucial: How Docker sees your Local Files)
# ----------------------------------------------------------
# Replace this with the ABSOLUTE path to your dataset on your host machine.
# This folder MUST contain the `data.yaml` file.
# E.g., /media/vocab/DATA5/SURIYA/CHITRA/DATA/Piping_White_Cement_Box_Annotation
HOST_DATA_PATH=/media/vocab/DATA5/SURIYA/CHITRA/DATA/Piping_White_Cement_Box_Annotation

# Inside Docker, `docker-compose` mounts `HOST_DATA_PATH` to `/app/data`.
# Yolo needs to know exactly where the yaml file is inside the container.
DATA_PATH=/app/data/data.yaml

# ----------------------------------------------------------
# 🧠 2. HYPERPARAMETERS
# ----------------------------------------------------------
# Base model to finetune from. Can be yolov8n.pt, yolov8s.pt, yolov8x.pt, etc.
# Ultralytics auto-downloads it if it's missing.
MODEL_NAME=yolov8n.pt

# Training Epochs - how many times to pass over the dataset
EPOCHS=60

# Image Size - multiple of 32
IMGSZ=640

# Device - "0" for the first GPU, "cpu" for CPU
DEVICE=0

# Batch Size - lower this if you get "CUDA Out Of Memory" (OOM) errors
BATCH_SIZE=16

# Save visual plots of the training process
PLOTS=True

# ----------------------------------------------------------
# 🗂️ 3. PROJECT IDENTIFICATION
# ----------------------------------------------------------
# Organizing where Docker saves the `.pt` weights
# The files will output locally to: `./runs/<PROJECT_NAME>/<RUN_NAME>`
PROJECT_NAME=finetuning_runs
RUN_NAME=yolo_white_cement
